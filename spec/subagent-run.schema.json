{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Subagent Run",
  "description": "Structured record for one subagent execution. This artifact is evidence for later evaluation; it does not replace parent-agent judgement.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subagent_run_id",
    "parent_run_id",
    "agent",
    "role",
    "mode",
    "purpose",
    "sandbox",
    "allowed_files",
    "input_files",
    "changed_files",
    "scope",
    "started_at",
    "ended_at",
    "status",
    "summary",
    "parent_decision",
    "used_in_final_plan",
    "evidence",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "enum": [
        1
      ],
      "description": "Schema version for the subagent run record."
    },
    "subagent_run_id": {
      "type": "string",
      "minLength": 1,
      "description": "Identifier for one subagent execution record."
    },
    "parent_run_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "description": "Parent run identifier when available."
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "model"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    },
    "role": {
      "type": "string",
      "enum": [
        "planner",
        "investigator",
        "reviewer",
        "implementation_worker",
        "validator",
        "other"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "read_only",
        "writable",
        "hybrid",
        "unknown"
      ]
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "sandbox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "network"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "read-only",
            "workspace-write",
            "danger-full-access",
            "unknown"
          ]
        },
        "network": {
          "type": "boolean"
        }
      }
    },
    "allowed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Maximum allowed change boundary for the subagent."
    },
    "input_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "declared",
        "compliant",
        "violations"
      ],
      "properties": {
        "declared": {
          "type": "boolean"
        },
        "compliant": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "violations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "started_at": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "ended_at": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "cancelled",
        "blocked",
        "not_run"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "parent_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "reason"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "accepted",
            "partially_accepted",
            "rejected",
            "deferred",
            "not_reviewed"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "used_in_final_plan": {
      "type": "boolean"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "value"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "path",
              "summary",
              "finding",
              "validation",
              "review_comment",
              "other"
            ]
          },
          "value": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Free-form metadata for the subagent run record."
    }
  }
}
