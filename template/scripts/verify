#!/usr/bin/env bash
set -u -o pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
cd "$repo_root"

pass_count=0
fail_count=0
skip_count=0

log_pass() {
  echo "PASS: $1"
  pass_count=$((pass_count + 1))
}

log_fail() {
  echo "FAIL: $1"
  fail_count=$((fail_count + 1))
}

log_skip() {
  echo "SKIP: $1"
  skip_count=$((skip_count + 1))
}

run_check() {
  local name="$1"
  shift
  if "$@"; then
    log_pass "$name"
  else
    log_fail "$name"
  fi
}

decision_from_json() {
  local output="$1"
  local decision
  decision="${output##*\"decision\":\"}"
  decision="${decision%%\"*}"
  [[ -n "$decision" && "$decision" != "$output" ]] || return 1
  printf '%s' "$decision"
}

contains() {
  local pattern="$1"
  local path="$2"
  if command -v rg >/dev/null 2>&1; then
    rg -q "$pattern" "$path"
  else
    grep -Fq "$pattern" "$path"
  fi
}

check_template_contract() {
  [[ -f AGENTS.md ]] || return 1
  [[ -f PLANS.md ]] || return 1
  [[ -f CODE_REVIEW.md ]] || return 1
  [[ -f MIGRATION.md ]] || return 1
  [[ -f codex-project.toml ]] || return 1
  [[ -f .codex/config.toml ]] || return 1
  [[ -f .codex/requirements.toml ]] || return 1
  [[ -f .codex/agents/code_researcher.toml ]] || return 1
  [[ -f .codex/agents/implementation_researcher.toml ]] || return 1
  [[ -f .codex/agents/implementation_worker.toml ]] || return 1
  [[ -f .codex/agents/test_investigator.toml ]] || return 1
  [[ -f .codex/hooks/pre_tool_use_policy.py ]] || return 1
  [[ -f .codex/hooks/pre_tool_use_policy.ps1 ]] || return 1
  [[ -f .codex/templates/PLAN.md ]] || return 1
  [[ -f .codex/rules/10-readonly-allow.rules ]] || return 1
  [[ -f .codex/rules-auto-net/10-auto-net-allow.rules ]] || return 1
  [[ -f .codex/rules-auto-net/20-auto-net-risky-forbidden.rules ]] || return 1
  [[ -f .codex/rules-auto-net/30-auto-net-forbidden.rules ]] || return 1
  [[ -f scripts/codex-task.ps1 ]] || return 1
  [[ -f scripts/codex-task.sh ]] || return 1
  [[ -f scripts/codex-sandbox.ps1 ]] || return 1
  [[ -f scripts/codex-sandbox.sh ]] || return 1
  [[ -f scripts/init-project.ps1 ]] || return 1
  [[ -f scripts/init-project.sh ]] || return 1
  [[ -f scripts/validate-output-schema.py ]] || return 1
  [[ -f .agents/skills/feature-plan/references/planning-workflow.md ]] || return 1
  [[ -f .agents/skills/code-review/references/review-workflow.md ]] || return 1
  [[ -f docs/reference/codex-safety-harness.md ]] || return 1
  [[ -f docs/reference/codex-implementation-harness.md ]] || return 1
  contains ".agents/skills/feature-plan/SKILL.md" AGENTS.md || return 1
  contains ".agents/skills/code-review/SKILL.md" AGENTS.md || return 1
  contains "docs/reference/codex-safety-harness.md" AGENTS.md || return 1
  contains "docs/reference/codex-implementation-harness.md" AGENTS.md || return 1
  contains "Report file" AGENTS.md || return 1
  contains "command-based deletion" AGENTS.md || return 1
  contains "implementation_worker" AGENTS.md || return 1
  contains "writable subagent" AGENTS.md || return 1
  contains ".agents/skills/feature-plan/SKILL.md" PLANS.md || return 1
  contains ".agents/skills/feature-plan/references/planning-workflow.md" PLANS.md || return 1
  contains "docs/plans/TEMPLATE.md" PLANS.md || return 1
  contains "Current understanding" PLANS.md || return 1
  contains "Non-goals" PLANS.md || return 1
  contains "Validation plan" PLANS.md || return 1
  contains "Open questions" PLANS.md || return 1
  contains "Ambiguity handling" PLANS.md || return 1
  contains "mandatory-question" PLANS.md || return 1
  contains ".agents/skills/code-review/SKILL.md" CODE_REVIEW.md || return 1
  contains ".agents/skills/code-review/references/review-workflow.md" CODE_REVIEW.md || return 1
  contains "findings-first" CODE_REVIEW.md || return 1
  contains "Why it matters" CODE_REVIEW.md || return 1
  contains "Suggested fix" CODE_REVIEW.md || return 1
  contains "Verdict" CODE_REVIEW.md || return 1
  contains "confidence" CODE_REVIEW.md || return 1
  contains "review-only" CODE_REVIEW.md || return 1
  contains "repo mapping" .agents/skills/feature-plan/references/planning-workflow.md || return 1
  contains "Do not use" .agents/skills/feature-plan/references/planning-workflow.md || return 1
  contains "Main flow" .agents/skills/feature-plan/references/planning-workflow.md || return 1
  contains "Key abstractions" .agents/skills/feature-plan/references/planning-workflow.md || return 1
  contains "Safe change surface" .agents/skills/feature-plan/references/planning-workflow.md || return 1
  contains "Validation candidates" .agents/skills/feature-plan/references/planning-workflow.md || return 1
  contains "Failure modes" .agents/skills/feature-plan/references/planning-workflow.md || return 1
  contains "Ambiguity handling" .agents/skills/feature-plan/references/planning-workflow.md || return 1
  contains "mandatory-question" .agents/skills/feature-plan/references/planning-workflow.md || return 1
  contains "Report file generation policy" .agents/skills/feature-plan/references/planning-workflow.md || return 1
  contains "diff triage" .agents/skills/code-review/references/review-workflow.md || return 1
  contains "Diff classification" .agents/skills/code-review/references/review-workflow.md || return 1
  contains "High-risk areas" .agents/skills/code-review/references/review-workflow.md || return 1
  contains "Potential missing tests" .agents/skills/code-review/references/review-workflow.md || return 1
  contains "Open questions" .agents/skills/code-review/references/review-workflow.md || return 1
  contains "Failure modes" .agents/skills/code-review/references/review-workflow.md || return 1
  contains "Report file generation policy" .agents/skills/code-review/references/review-workflow.md || return 1
  contains "sandbox_mode = \"workspace-write\"" .codex/config.toml || return 1
  contains "approval_policy = \"untrusted\"" .codex/config.toml || return 1
  contains "web_search = \"cached\"" .codex/config.toml || return 1
  contains "network_access = false" .codex/config.toml || return 1
  contains "[profiles.repo_auto_net]" .codex/config.toml || return 1
  contains "network_access = true" .codex/config.toml || return 1
  contains "codex_hooks = true" .codex/config.toml || return 1
  contains "pre_tool_use_policy.ps1" .codex/config.toml || return 1
  contains "name = \"implementation_worker\"" .codex/agents/implementation_worker.toml || return 1
  contains "model = \"gpt-5.4-mini\"" .codex/agents/implementation_worker.toml || return 1
  contains "sandbox_mode = \"workspace-write\"" .codex/agents/implementation_worker.toml || return 1
  contains "親 agent が明示した計画" .codex/agents/implementation_worker.toml || return 1
  contains "親 agent が指定していないファイルを編集しない" .codex/agents/implementation_worker.toml || return 1
  contains "command-based deletion is forbidden" .codex/agents/implementation_worker.toml || return 1
  contains "スコープ遵守確認" .codex/agents/implementation_worker.toml || return 1
  contains "指定外ファイルを変更していないことの確認" .codex/agents/implementation_worker.toml || return 1
  contains "削除 / rename / git mutation を行っていないことの確認" .codex/agents/implementation_worker.toml || return 1
}

check_execpolicy_baseline() {
  local rule_args=(
    --rules .codex/rules/10-readonly-allow.rules
    --rules .codex/rules/20-risky-prompt.rules
    --rules .codex/rules/30-destructive-forbidden.rules
  )

  local out decision
  local git_bin="g""it"
  local add_subcmd="a""dd"
  local reset_subcmd="re""set"
  local hard_flag="--h""ard"
  local clean_subcmd="cl""ean"
  local remove_bin="r""m"

  out="$(codex execpolicy check "${rule_args[@]}" -- "$git_bin" status)" || return 1
  decision="$(decision_from_json "$out")" || return 1
  [[ "$decision" == "allow" ]] || return 1

  out="$(codex execpolicy check "${rule_args[@]}" -- "$git_bin" "$add_subcmd" .)" || return 1
  decision="$(decision_from_json "$out")" || return 1
  [[ "$decision" == "forbidden" ]] || return 1

  out="$(codex execpolicy check "${rule_args[@]}" -- "$git_bin" "$reset_subcmd" "$hard_flag" HEAD~1)" || return 1
  decision="$(decision_from_json "$out")" || return 1
  [[ "$decision" == "forbidden" ]] || return 1

  out="$(codex execpolicy check "${rule_args[@]}" -- "$remove_bin" file.txt)" || return 1
  decision="$(decision_from_json "$out")" || return 1
  [[ "$decision" == "forbidden" ]] || return 1

  out="$(codex execpolicy check "${rule_args[@]}" -- "$git_bin" "$remove_bin" file.txt)" || return 1
  decision="$(decision_from_json "$out")" || return 1
  [[ "$decision" == "forbidden" ]] || return 1

  out="$(codex execpolicy check "${rule_args[@]}" -- "$git_bin" "$clean_subcmd" -fdx)" || return 1
  decision="$(decision_from_json "$out")" || return 1
  [[ "$decision" == "forbidden" ]] || return 1

  return 0
}

check_codex_available() {
  command -v codex >/dev/null 2>&1 && codex --version >/dev/null 2>&1
}

check_bash_wrapper_preflight() {
  bash scripts/codex-safe.sh --preflight-only >/tmp/codex-safe-preflight.log 2>&1
}

check_powershell_has_codex() {
  powershell.exe -NoProfile -Command "if (Get-Command codex -ErrorAction SilentlyContinue) { exit 0 } else { exit 1 }" >/dev/null 2>&1
}

check_powershell_wrapper_preflight() {
  powershell.exe -ExecutionPolicy Bypass -File scripts/codex-safe.ps1 -PreflightOnly >/tmp/codex-safe-ps-preflight.log 2>&1
}

run_check "template contract files" check_template_contract

if ! check_codex_available; then
  log_skip "execpolicy checks (codex command not executable)"
else
  run_check "execpolicy baseline decisions" check_execpolicy_baseline
fi

if [[ -f scripts/codex-safe.sh ]] && check_codex_available; then
  run_check "bash wrapper preflight" check_bash_wrapper_preflight
else
  log_skip "bash wrapper preflight (codex command not executable or wrapper not found)"
fi

if command -v powershell.exe >/dev/null 2>&1; then
  if check_powershell_has_codex; then
    run_check "PowerShell wrapper preflight" check_powershell_wrapper_preflight
  else
    log_skip "PowerShell wrapper preflight (codex not found in PowerShell PATH)"
  fi
else
  log_skip "PowerShell wrapper preflight (powershell.exe not available)"
fi

echo "Summary: PASS=$pass_count FAIL=$fail_count SKIP=$skip_count"

if (( fail_count > 0 )); then
  exit 1
fi

exit 0
