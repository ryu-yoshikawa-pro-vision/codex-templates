#!/usr/bin/env bash
set -u -o pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
source_repo_root="$(cd "$repo_root/.." && pwd -P)"
cd "$repo_root"

pass_count=0
fail_count=0
skip_count=0

log_pass() {
  echo "PASS: $1"
  pass_count=$((pass_count + 1))
}

log_fail() {
  echo "FAIL: $1"
  fail_count=$((fail_count + 1))
}

log_skip() {
  echo "SKIP: $1"
  skip_count=$((skip_count + 1))
}

run_check() {
  local name="$1"
  shift
  if "$@"; then
    log_pass "$name"
  else
    log_fail "$name"
  fi
}

decision_from_json() {
  local output="$1"
  local decision
  decision="${output##*\"decision\":\"}"
  decision="${decision%%\"*}"
  [[ -n "$decision" && "$decision" != "$output" ]] || return 1
  printf '%s' "$decision"
}

contains() {
  local pattern="$1"
  local path="$2"
  if command -v rg >/dev/null 2>&1 && rg --version >/dev/null 2>&1; then
    rg -Fq -- "$pattern" "$path"
  else
    grep -Fq -- "$pattern" "$path"
  fi
}

has_change_scope_catalog() {
  if [[ -f "spec/change-scope-policy.json" ]]; then
    return 0
  fi

  if [[ -d "$source_repo_root/spec" && -d "$source_repo_root/template" ]]; then
    [[ -f "$source_repo_root/spec/change-scope-policy.json" ]]
    return
  fi

  return 0
}

