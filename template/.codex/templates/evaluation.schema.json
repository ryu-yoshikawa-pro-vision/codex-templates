{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Harness Evaluation",
  "description": "Canonical evaluation artifact for one run. Observed execution facts are referenced from run.json, codex-task report JSON, or logs; the agent or reviewer records interpretation here.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "result",
    "primary_failure_category",
    "failure_categories",
    "dimensions",
    "findings",
    "improvement_candidates"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "enum": [
        1
      ],
      "description": "Schema version for the evaluation artifact."
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "description": "Run identifier shared with run.json and run-local artifacts."
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "partial",
        "fail",
        "not_evaluated"
      ],
      "description": "Overall outcome judgement for the run."
    },
    "primary_failure_category": {
      "enum": [
        null,
        "instruction_gap",
        "scope_creep",
        "missing_context",
        "missing_validation",
        "unsafe_action_blocked",
        "bad_subagent_delegation",
        "flaky_or_env_issue",
        "review_gap",
        "repair_loop_stalled",
        "artifact_contract_gap"
      ],
      "description": "Primary failure category selected from spec/failure-taxonomy.json. Null is allowed before evaluation is complete or when failure classification is unnecessary. For result=fail or result=partial, a non-null value is usually expected."
    },
    "failure_categories": {
      "type": "array",
      "description": "Failure categories chosen from spec/failure-taxonomy.json. When primary_failure_category is non-null, it should also appear in this array.",
      "items": {
        "type": "string",
        "enum": [
          "instruction_gap",
          "scope_creep",
          "missing_context",
          "missing_validation",
          "unsafe_action_blocked",
          "bad_subagent_delegation",
          "flaky_or_env_issue",
          "review_gap",
          "repair_loop_stalled",
          "artifact_contract_gap"
        ]
      }
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_completion",
        "scope_control",
        "validation_confidence",
        "safety_compliance",
        "reviewability",
        "maintainability",
        "reproducibility"
      ],
      "properties": {
        "task_completion": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "rating",
            "evidence"
          ],
          "properties": {
            "rating": {
              "type": "string",
              "enum": [
                "pass",
                "warn",
                "fail",
                "not_evaluated"
              ]
            },
            "evidence": {
              "type": "string",
              "minLength": 1,
              "description": "Evidence supporting the rating. Even when not_evaluated, record why the dimension was not evaluated."
            },
            "evidence_refs": {
              "type": "array",
              "description": "Optional structured references to run artifacts that support the evidence string.",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "kind",
                  "summary"
                ],
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "run_manifest",
                      "codex_task_report",
                      "log_event",
                      "hook_observation",
                      "subagent_run",
                      "changed_file",
                      "validation_command",
                      "evaluation_note"
                    ]
                  },
                  "path": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "selector": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "event_id": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "summary": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
